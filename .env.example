# Trading Assistant Configuration
# Copy to .env and fill in real values.
# Load with: export $(grep -v '^#' .env | xargs)

# === Bot Configuration ===
BOT_IDS=bot_alpha,bot_beta

# === Relay VPS ===
RELAY_URL=https://relay.yourvps.com
RELAY_HMAC_SECRET=changeme

# === Telegram ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Discord (optional) ===
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# === Email (optional) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=

# === Paths ===
DATA_DIR=.

# === Logging ===
LOG_LEVEL=INFO
