# Trading Assistant Configuration
# Copy to .env and fill in real values.
# The orchestrator auto-loads .env for local runs; exported process env vars still win.

# === Bot Configuration ===
BOT_IDS=k_stock_trader,stock_trader,swing_multi_01,momentum_nq_01
# Per-bot timezone overrides (format: bot_id:IANA_tz,bot_id2:IANA_tz)
# Bots not listed default to UTC. Used for daily analysis scheduling + hourly bucketing.
BOT_TIMEZONES=k_stock_trader:Asia/Seoul,stock_trader:US/Eastern,swing_multi_01:US/Eastern,momentum_nq_01:US/Eastern,crypto_trader:UTC:00:00

# === Agent Runtime ===
# CLI commands used by the provider-backed agent runner
# Claude Max must be logged in locally via `claude auth login`.
# Verify readiness with `claude auth status` before selecting `claude_max`.
CLAUDE_COMMAND=claude
# Optional JSON-array launcher args, e.g. ["--"] for a wrapper command.
CLAUDE_COMMAND_ARGS=
CODEX_COMMAND=codex
# Optional JSON-array launcher args, e.g. ["--", "codex"] for `wsl.exe`.
CODEX_COMMAND_ARGS=

# Provider-backed credentials
# `claude_max` uses the local Claude Code login, not an API key.
ZAI_API_KEY=
OPENROUTER_API_KEY=

# Optional initial defaults for the provider switcher.
# These seed data/agent_preferences.json only if no persisted file exists yet.
AGENT_PROVIDER=claude_max
AGENT_MODEL=
DAILY_AGENT_PROVIDER=
DAILY_AGENT_MODEL=
WEEKLY_AGENT_PROVIDER=
WEEKLY_AGENT_MODEL=
TRIAGE_AGENT_PROVIDER=
TRIAGE_AGENT_MODEL=

# === Relay VPS ===
RELAY_URL=https://relay.yourvps.com
# API key for authenticating GET requests to relay read endpoints
RELAY_API_KEY=

# Required unless ALLOW_UNAUTHENTICATED_LOCAL=true and binding only to loopback.
ORCHESTRATOR_API_KEY=
ALLOW_UNAUTHENTICATED_LOCAL=false
BIND_HOST=127.0.0.1

# === Telegram ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Discord (optional) ===
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# === Email (optional) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=

# === Paths ===
DATA_DIR=data
BOT_CONFIG_DIR=data/bot_configs
BOT_REPO_DIR=.
BOT_REPO_CACHE_DIR=runs/repo_cache
GITHUB_TOKEN=

# === Monthly Evidence & Replay Foundation ===
# Disabled by default. Use MONTHLY_VALIDATION_MODE=shadow for dry runs that
# write manifests, reports, and ledgers but never create approval-ready actions.
MONTHLY_VALIDATION_ENABLED=false
MONTHLY_VALIDATION_MODE=disabled
MONTHLY_OPTIMIZER_SEQUENCE_ENABLED=true
# Optional JSON array override. Empty uses the default backtest runner module.
MONTHLY_BACKTEST_COMMAND=
MONTHLY_WORKFLOW_CONTRACT_PATH=
MONTHLY_WORKFLOW_CONTRACT_VERSION=
MONTHLY_STRATEGY_PLUGIN_CONTRACT_PATH=
MARKET_DATA_ROOT=../trading_data/market
BACKTEST_REPO_PATH=../trading_backtests
BACKTEST_ARTIFACT_ROOT=../trading_data/runs/monthly_validation
MARKET_DATA_REQUIRED_COVERAGE_RATIO=0.95
TELEMETRY_REQUIRED_LINEAGE_RATIO=0.95
MARKET_DATA_SYNC_DAY_OF_MONTH=1
MARKET_DATA_SYNC_HOUR=1
MARKET_DATA_SYNC_MINUTE=0
MONTHLY_VALIDATION_DAY_OF_MONTH=2
MONTHLY_VALIDATION_HOUR=3
MONTHLY_VALIDATION_MINUTE=0
BACKTEST_COMMAND_TIMEOUT_SECONDS=3600
BACKTEST_MAX_PARALLEL_STRATEGIES=1

# === Learning Review ===
# deterministic is offline and safe by default. llm_review requires configured
# agent providers and still validates structured actions before writing.
LEARNING_REVIEW_MODE=deterministic
LEARNING_REVIEW_DISABLED_WORKFLOWS=

# === Logging ===
LOG_LEVEL=INFO
