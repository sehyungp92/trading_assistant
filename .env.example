# Trading Assistant Configuration
# Copy to .env and fill in real values.
# Load with: export $(grep -v '^#' .env | xargs)

# === Bot Configuration ===
BOT_IDS=bot_alpha,bot_beta
# Per-bot timezone overrides (format: bot_id:IANA_tz,bot_id2:IANA_tz)
# Bots not listed default to UTC. Used for daily analysis scheduling + hourly bucketing.
# BOT_TIMEZONES=k_stock_trader:Asia/Seoul,us_bot:US/Eastern

# === Relay VPS ===
RELAY_URL=https://relay.yourvps.com
RELAY_HMAC_SECRET=changeme
# API key for authenticating GET requests to relay read endpoints
RELAY_API_KEY=

# === Telegram ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Discord (optional) ===
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# === Email (optional) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=

# === Paths ===
DATA_DIR=.

# === Logging ===
LOG_LEVEL=INFO
